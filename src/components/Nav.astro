---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/the-story', label: 'The Story' },
  { href: '/the-world', label: 'The World' },
  { href: '/characters', label: 'Characters' },
  { href: '/about', label: 'About' },
  { href: '/book-clubs', label: 'Book Clubs' },
  { href: '/press', label: 'Press' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-nav">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <!-- Logo / Title -->
      <a href="/" class="font-display text-lg sm:text-xl text-amber hover:text-amber-dark transition-colors">
        Secrets of Pagua Bay
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-2 text-sm tracking-wide transition-colors duration-200',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-amber'
                : 'text-salt/70 hover:text-salt',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/the-story#buy"
          class="ml-3 px-5 py-2 bg-amber text-charcoal text-sm font-semibold rounded hover:bg-amber-dark transition-colors"
        >
          Get the Book
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-salt/70 hover:text-salt transition-colors relative z-[70]"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay - outside nav to avoid stacking context issues -->
<div
  id="mobile-menu"
  class="lg:hidden fixed inset-0 z-[60] -translate-x-full"
  style="background-color: #1A1A2E;"
>
  <!-- Close button -->
  <button
    id="mobile-menu-close"
    class="absolute top-5 right-5 p-2 text-salt/70 hover:text-salt transition-colors"
    aria-label="Close menu"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <div class="flex flex-col items-center justify-center h-full gap-6 pb-20">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          'text-2xl font-display tracking-wide transition-colors',
          currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
            ? 'text-amber'
            : 'text-salt/80 hover:text-salt',
        ]}
      >
        {link.label}
      </a>
    ))}
    <a
      href="/the-story#buy"
      class="mt-4 px-8 py-3 bg-amber text-charcoal text-lg font-semibold rounded hover:bg-amber-dark transition-colors"
    >
      Get the Book
    </a>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const closeBtn = document.getElementById('mobile-menu-close');
  let isOpen = false;

  // Add transition after load to prevent flash on page init
  requestAnimationFrame(() => {
    menu?.classList.add('transition-transform', 'duration-300', 'ease-in-out');
  });

  function toggleMenu(open: boolean) {
    isOpen = open;
    menu?.classList.toggle('-translate-x-full', !isOpen);
    menu?.classList.toggle('translate-x-0', isOpen);
    btn?.setAttribute('aria-expanded', String(isOpen));
  }

  btn?.addEventListener('click', () => toggleMenu(!isOpen));
  closeBtn?.addEventListener('click', () => toggleMenu(false));

  // Close menu on link click
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggleMenu(false);
    });
  });

  // Nav background on scroll
  const nav = document.getElementById('main-nav');
  const observer = new IntersectionObserver(
    ([entry]) => {
      if (!entry.isIntersecting) {
        nav?.style.setProperty('background', 'rgba(26,26,46,0.95)');
        nav?.classList.add('backdrop-blur-md', 'shadow-lg', 'shadow-black/20');
      } else {
        nav?.style.removeProperty('background');
        nav?.classList.remove('backdrop-blur-md', 'shadow-lg', 'shadow-black/20');
      }
    },
    { threshold: 0 }
  );

  const sentinel = document.getElementById('nav-sentinel');
  if (sentinel) observer.observe(sentinel);
</script>
