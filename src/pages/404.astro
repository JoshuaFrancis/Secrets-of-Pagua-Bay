---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Secrets of Pagua Bay"
  description="The page you're looking for doesn't exist."
>
  <section class="relative min-h-[70vh] flex items-center justify-center ambient-bg overflow-hidden">
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-amber text-sm tracking-widest uppercase mb-4 font-medium section-fade">
        Lost in the Village
      </p>
      <h1 class="font-display text-5xl sm:text-7xl text-salt mb-6 section-fade">
        This path leads nowhere
      </h1>
      <p class="text-salt/60 max-w-xl mx-auto mb-10 section-fade" style="animation-delay: 0.2s">
        The page you're looking for has vanished — like smoke over Pagua Bay.
      </p>

      <!-- Fire divider -->
      <div class="my-8 flex items-center justify-center gap-4 section-fade" style="animation-delay: 0.4s" aria-hidden="true">
        <div class="h-px w-16 bg-gradient-to-r from-transparent to-amber/30"></div>
        <svg class="w-6 h-6 text-amber/40" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C12 2 6 10 6 16a6 6 0 0012 0c0-6-6-14-6-14zm0 18a3 3 0 01-3-3c0-3 3-8 3-8s3 5 3 8a3 3 0 01-3 3z"/>
        </svg>
        <div class="h-px w-16 bg-gradient-to-l from-transparent to-amber/30"></div>
      </div>

      <div class="section-fade" style="animation-delay: 0.6s">
        <a
          href="/"
          class="inline-block px-8 py-3 border border-salt/20 text-salt/80 text-sm rounded hover:border-amber hover:text-amber transition-colors"
        >
          Return Home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
